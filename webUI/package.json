{
  "name": "y",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typegen": "npx @openapitools/openapi-generator-cli generate -i http://localhost:8080/api/openapi.json -g typescript-fetch -o src/generated/client && npm run fmt -- src/generated/client",
    "build": "vite build",
    "lint": "oxlint src --max-warnings 0 --fix",
    "preview": "vite preview",
    "build-storybook": "storybook build",
    "storybook": "storybook dev -p 6006",
    "compile": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "verify": "npm run fmt:check && npm run lint && npm run compile",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/ubuntu": "^5.2.8",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-data-grid": "^9.0.2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lodash": "^4.18.1",
    "plotly.js": "^3.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@storybook/react-vite": "^10.3.5",
    "@types/lodash": "^4.17.24",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^4.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^8.44.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "eslint-plugin-storybook": "^10.3.5",
    "jsdom": "^29.0.2",
    "msw": "^2.13.4",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "storybook": "^10.3.5",
    "typescript": "^6.0.2",
    "vite": "^4.4.0",
    "vitest": "^4.1.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
